<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB"
    tools:context=".EducationHubActivity">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Back"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Education Hub"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Daily Tip Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFF9E6">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <ImageView
                        android:id="@+id/ivTipIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tip"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTipLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Daily Tip"
                        android:textColor="#F59E0B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/ivTipIcon"
                        app:layout_constraintStart_toEndOf="@id/ivTipIcon"
                        app:layout_constraintTop_toTopOf="@id/ivTipIcon" />

                    <TextView
                        android:id="@+id/tvTipTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Rinse Before You Bin"
                        android:textColor="@color/text_dark"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/ivTipIcon" />

                    <TextView
                        android:id="@+id/tvTipDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Food residue can contaminate an entire batch of recyclables. A quick rinse makes a huge difference!"
                        android:textColor="@color/text_grey"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/tvTipTitle" />

                    <TextView
                        android:id="@+id/btnReadMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Read More →"
                        android:textColor="#D97706"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTipDesc" />

                    <!-- Decorative Circle -->
                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/circle_bg"
                        android:backgroundTint="#1A000000"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginEnd="-40dp"
                        android:layout_marginTop="-40dp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Learning Paths"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Learning Path 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivPath1Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/white_rounded_rect"
                        android:backgroundTint="#E3F2FD"
                        android:padding="12dp"
                        android:src="@drawable/ic_education"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#1E88E5" />

                    <TextView
                        android:id="@+id/tvPath1Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Recycling Guide"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvPath1Count"
                        app:layout_constraintStart_toEndOf="@id/ivPath1Icon"
                        app:layout_constraintTop_toTopOf="@id/ivPath1Icon" />

                    <TextView
                        android:id="@+id/tvPath1Count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 articles"
                        android:textColor="@color/text_light_grey"
                        android:textSize="12sp"
                        android:gravity="end"
                        app:layout_constraintEnd_toStartOf="@+id/ivPath1Arrow"
                        app:layout_constraintTop_toTopOf="@id/tvPath1Title"
                        android:layout_marginEnd="16dp"/>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:progress="60"
                        android:progressTint="#1E88E5"
                        app:layout_constraintEnd_toEndOf="@id/tvPath1Title"
                        app:layout_constraintStart_toStartOf="@id/tvPath1Title"
                        app:layout_constraintTop_toBottomOf="@id/tvPath1Title" />

                    <ImageView
                        android:id="@+id/ivPath1Arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_light_grey" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Learning Path 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivPath2Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/white_rounded_rect"
                        android:backgroundTint="#D1FAE5"
                        android:padding="12dp"
                        android:src="@drawable/ic_composting"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvPath2Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Composting 101"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvPath2Count"
                        app:layout_constraintStart_toEndOf="@id/ivPath2Icon"
                        app:layout_constraintTop_toTopOf="@id/ivPath2Icon" />

                    <TextView
                        android:id="@+id/tvPath2Count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8 articles"
                        android:textColor="@color/text_light_grey"
                        android:textSize="12sp"
                        android:gravity="end"
                        app:layout_constraintEnd_toStartOf="@+id/ivPath2Arrow"
                        app:layout_constraintTop_toTopOf="@id/tvPath2Title"
                        android:layout_marginEnd="16dp"/>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:progress="30"
                        android:progressTint="#43A047"
                        app:layout_constraintEnd_toEndOf="@id/tvPath2Title"
                        app:layout_constraintStart_toStartOf="@id/tvPath2Title"
                        app:layout_constraintTop_toBottomOf="@id/tvPath2Title" />

                    <ImageView
                        android:id="@+id/ivPath2Arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_light_grey" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Learning Path 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivPath3Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/white_rounded_rect"
                        android:backgroundTint="#FFEBEE"
                        android:padding="12dp"
                        android:src="@drawable/ic_urgent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#E53935" />

                    <TextView
                        android:id="@+id/tvPath3Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Hazardous Waste"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvPath3Count"
                        app:layout_constraintStart_toEndOf="@id/ivPath3Icon"
                        app:layout_constraintTop_toTopOf="@id/ivPath3Icon" />

                    <TextView
                        android:id="@+id/tvPath3Count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 articles"
                        android:textColor="@color/text_light_grey"
                        android:textSize="12sp"
                        android:gravity="end"
                        app:layout_constraintEnd_toStartOf="@+id/ivPath3Arrow"
                        app:layout_constraintTop_toTopOf="@id/tvPath3Title"
                        android:layout_marginEnd="16dp"/>

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:progress="80"
                        android:progressTint="#E53935"
                        app:layout_constraintEnd_toEndOf="@id/tvPath3Title"
                        app:layout_constraintStart_toStartOf="@id/tvPath3Title"
                        app:layout_constraintTop_toBottomOf="@id/tvPath3Title" />

                    <ImageView
                        android:id="@+id/ivPath3Arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_light_grey" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>